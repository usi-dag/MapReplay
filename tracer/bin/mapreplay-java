#!/bin/bash
set -euo pipefail

# ===========================================
# MapReplay JVM wrapper
# ===========================================

REAL_PATH=$(realpath "$0")
BIN_DIR=$(dirname "$REAL_PATH")
BASE_DIR=$(realpath "$BIN_DIR/..")
LIB_DIR="$BASE_DIR/lib"

PATCH_JAR="$LIB_DIR/mapreplay-patch.jar"
AGENT_JAR="$LIB_DIR/mapreplay-agent.jar"
NATIVE_LIB="$LIB_DIR/libmapreplay-tracer.so"

JAVA_CMD="${JAVA_HOME:?JAVA_HOME must be set}/bin/java"

export LOG_TRACER="${LOG_TRACER:-false}"

# Basic sanity checks
[ -f "$PATCH_JAR" ] || { echo "Missing patch JAR: $PATCH_JAR" >&2; exit 1; }
[ -f "$AGENT_JAR" ] || { echo "Missing Java agent JAR: $AGENT_JAR" >&2; exit 1; }
[ -f "$NATIVE_LIB" ] || { echo "Missing native agent: $NATIVE_LIB" >&2; exit 1; }
[ -x "$JAVA_CMD" ] || { echo "JAVA_HOME does not point to a valid JDK/JRE: $JAVA_HOME" >&2; exit 1; }

JVM_OPTS=(
  "--patch-module=java.base=$PATCH_JAR"
  "--add-exports=java.base/jdk.internal.mapreplay=ALL-UNNAMED"
  "-agentpath:$NATIVE_LIB"
  "-javaagent:$AGENT_JAR"
  "-Dtracer.logEnabled=$LOG_TRACER"
)

if [ -n "${DEBUG_SCRIPT:-}" ]; then
  printf '%q ' "$JAVA_CMD" "${JVM_OPTS[@]}" "$@"
  echo
fi

exec "$JAVA_CMD" "${JVM_OPTS[@]}" "$@"